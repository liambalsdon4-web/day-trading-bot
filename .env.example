# ── Trading Mode ──────────────────────────────────────────────────────────────
# "paper" = simulate trades with no real money (DEFAULT — safe to start here)
# "live"  = execute real trades (requires broker credentials + CONFIRM_LIVE_TRADING)
MODE=paper

# ── Symbols to trade ──────────────────────────────────────────────────────────
# JSON array of stock tickers (US stocks via yfinance in paper mode, Alpaca in live)
STOCK_SYMBOLS=["AAPL","TSLA","NVDA"]

# JSON array of crypto pairs (yfinance format: BTC-USD; CCXT format for live: BTC/USDT)
CRYPTO_SYMBOLS=["BTC-USD","ETH-USD"]

# ── Alpaca (Stocks) ───────────────────────────────────────────────────────────
# Sign up free at https://alpaca.markets — paper trading works without approval
# Leave blank to use built-in paper broker (no external API calls)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
# Set to false ONLY when you want live stock trading via Alpaca
ALPACA_PAPER=true

# ── Crypto (CCXT / Binance) ───────────────────────────────────────────────────
CRYPTO_EXCHANGE=binance
BINANCE_API_KEY=
BINANCE_SECRET=

# ── Live trading safety gate ──────────────────────────────────────────────────
# Must be set to EXACTLY "YES_I_UNDERSTAND" to place real orders
# Leave blank for paper trading
CONFIRM_LIVE_TRADING=

# ── Risk parameters ───────────────────────────────────────────────────────────
STARTING_CAPITAL=10000.0
MAX_POSITIONS=5
# 1% of capital at risk per trade
RISK_PER_TRADE_PCT=0.01
# 2% stop loss below entry
STOP_LOSS_PCT=0.02
# 4% take profit above entry (2:1 risk/reward)
TAKE_PROFIT_PCT=0.04
# Halt new entries after 2% daily drawdown
DAILY_LOSS_LIMIT_PCT=0.02

# ── Signal thresholds ─────────────────────────────────────────────────────────
# net_score >= BUY_THRESHOLD → BUY signal
BUY_THRESHOLD=40.0
# net_score <= SELL_THRESHOLD → SELL signal
SELL_THRESHOLD=-40.0

# ── Loop timing ───────────────────────────────────────────────────────────────
TICK_INTERVAL_SECONDS=60
# Set true to run outside NYSE hours (useful for testing)
FORCE_RUN=false

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000
